            <trans-unit id="VGhpcyB1c2VyIGFscmVhZHkgaXMgaW4gdXNlLiA8YnIvPlBsZWFzZSB3YWl0IHVudGlsIGl0IGlzIGF2YWlsYWJsZSBhZ2FpbiBvciB1c2UgYW5vdGhlciB1c2VyIQ==">
                <source>This user already is in use. <br/>Please wait until it is available again or use another user!</source>
                <target>Dieser Benutzer wird bereits verwendet. <br/>Bitte warten Sie, bis der Benutzer wieder verfügbar ist, oder benutzen Sie einen anderen!</target>
            </trans-unit>
            <trans-unit id="VW5hdXRoZW50aWNhdGVkIQ==">
                <source>Unauthenticated!</source>
                <target></target>
            </trans-unit>
            <trans-unit id="V2UgYXBvbG9naXplIGZvciB0aGUgcHJvYmxlbSB5b3UgZW5jb3VudGVyZWQh">
                <source>We apologize for the problem you encountered!</source>
                <target>Ci scusiamo per il disturbo!</target>
            </trans-unit>
            <trans-unit id="V2UgY291bGRu4oCZdCBsb2cgeW91IGluLjxici8+Rm9yZ290IHlvdXIgcGFzc3dvcmQsIG9yIGhhdmVu4oCZdCBzZXQgb25lIHlldD8gUmVxdWVzdCBhIG5ldyBsaW5rICVzaGVyZSVzIGFueXRpbWUu">
                <source>We couldn’t log you in.<br/>Forgot your password, or haven’t set one yet? Request a new link %shere%s anytime.</source>
                <target>Ungültige Logindaten!<br/>Haben Sie Ihr Passwort vergessen oder bislang noch kein Passwort für Ihren Login gesetzt? Sie können %shier%s jederzeit einen neuen Link anfordern.</target>
            </trans-unit>
            <trans-unit id="V2XigJlsbCBiZSBiYWNrIDxici8+c29vbiE=">
                <source>We’ll be back <br/>soon!</source>
                <target>Wir sind <br/>bald wieder da!</target>
            </trans-unit>
            <trans-unit id="V2XigJlyZSBhYm91dCB0byBzdGFydCBtYWludGVuYW5jZSwgc28gbG9naW5zIGFyZSB0ZW1wb3JhcmlseSB1bmF2YWlsYWJsZS4gUGxlYXNlIHRyeSBhZ2FpbiBpbiBhIGZldyBtaW51dGVzLg==">
                <source>We’re about to start maintenance, so logins are temporarily unavailable. Please try again in a few minutes.</source>
                <target>Intervento di manutenzione imminente. Non è possibile effettuare il login. Riprovare più tardi.</target>
            </trans-unit>
